{
  "realm": "mocapi-demo",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "defaultDefaultClientScopes": [
    "catalog:read",
    "catalog:analyze",
    "feedback:write"
  ],
  "clientScopes": [
    {
      "name": "catalog:read",
      "description": "Read-only access to the service/team lookup + list tools.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "catalog:analyze",
      "description": "Access to dependency / blast-radius / deprecation-debt analysis tools.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "feedback:write",
      "description": "Ability to submit feedback + suggest-tool proposals back to the server.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "meridian-viewer",
      "name": "Meridian Viewer (catalog:read)",
      "description": "Read-only persona. Everyday service/team lookup and discovery — the 80% hit.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "meridian-viewer-secret",
      "defaultClientScopes": ["catalog:read"],
      "optionalClientScopes": [],
      "attributes": {
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "meridian-oncall",
      "name": "Meridian Oncall (catalog:read + catalog:analyze)",
      "description": "2am-page persona. Adds dependency traversal, blast-radius, orphaned + deprecated analysis for incident triage and migration planning.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "meridian-oncall-secret",
      "defaultClientScopes": ["catalog:read", "catalog:analyze"],
      "optionalClientScopes": [],
      "attributes": {
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "mocapi-inspector",
      "name": "MCP Inspector (interactive user login, authorization code + PKCE)",
      "description": "Public OAuth client for the MCP Inspector UI. Interactive users (e.g. 'demo') log in through Keycloak's hosted login page; Inspector receives the authorization code and exchanges it for an audience-bound access token.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "webOrigins": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.signed.response.alg": "RS256",
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": ["catalog:read", "catalog:analyze", "feedback:write"],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "meridian-owner",
      "name": "Meridian Owner (all scopes)",
      "description": "Catalog maintainer persona. Adds feedback + tool-proposal submission for evolving the server itself.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "meridian-owner-secret",
      "defaultClientScopes": ["catalog:read", "catalog:analyze", "feedback:write"],
      "optionalClientScopes": [],
      "attributes": {
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8080/mcp",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "components": {
    "org.keycloak.services.clientregistration.policy.ClientRegistrationPolicy": [
      {
        "name": "Trusted Hosts",
        "providerId": "trusted-hosts",
        "subType": "anonymous",
        "subComponents": {},
        "config": {
          "trusted-hosts": ["localhost", "127.0.0.1"],
          "host-sending-registration-request-must-match": ["true"],
          "client-uris-must-match": ["true"]
        }
      },
      {
        "name": "Consent Required",
        "providerId": "consent-required",
        "subType": "anonymous",
        "subComponents": {},
        "config": {}
      },
      {
        "name": "Full Scope Disabled",
        "providerId": "scope",
        "subType": "anonymous",
        "subComponents": {},
        "config": {}
      },
      {
        "name": "Max Clients Limit",
        "providerId": "max-clients",
        "subType": "anonymous",
        "subComponents": {},
        "config": {
          "max-clients": ["200"]
        }
      },
      {
        "name": "Allowed Protocol Mapper Types",
        "providerId": "allowed-protocol-mappers",
        "subType": "anonymous",
        "subComponents": {},
        "config": {
          "allowed-protocol-mapper-types": [
            "oidc-address-mapper",
            "oidc-full-name-mapper",
            "oidc-sha256-pairwise-sub-mapper",
            "oidc-usermodel-attribute-mapper",
            "oidc-usermodel-property-mapper",
            "oidc-usersessionmodel-note-mapper",
            "saml-role-list-mapper",
            "saml-user-attribute-mapper",
            "saml-user-property-mapper"
          ]
        }
      }
    ]
  },
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo@mocapi-demo.local",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-mocapi-demo"]
    }
  ]
}
